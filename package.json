    "jsdom": "^28.0.0",
    "mssql": "^12.2.0",
    "oxfmt": "latest",
    "oxlint": "^1.43.0",
    "postgres": "^3.4.8",
    "tailwindcss": "^4.1.18",
    "ts-morph": "^27.0.2",
    "typescript": "^5.9.3"
